{
  "databases": [
    {
      "name": "mysql-main",
      "type": "mysql",
      "host": "localhost",
      "port": 3306,
      "user": "root",
      "password": "${DB_MYSQL_PASSWORD}",
      "database": "myapp",
      "description": "MySQL 主库",
      "isDefault": true
    },
    {
      "name": "postgres-analytics",
      "type": "postgres",
      "host": "localhost",
      "port": 5432,
      "user": "postgres",
      "password": "${DB_PG_PASSWORD}",
      "database": "analytics",
      "description": "PostgreSQL 分析库"
    },
    {
      "name": "redis-cache",
      "type": "redis",
      "host": "localhost",
      "port": 6379,
      "password": "${DB_REDIS_PASSWORD}",
      "database": "0",
      "description": "Redis 缓存"
    },
    {
      "name": "mongodb-logs",
      "type": "mongodb",
      "host": "localhost",
      "port": 27017,
      "user": "admin",
      "password": "${DB_MONGO_PASSWORD}",
      "database": "logs",
      "authSource": "admin",
      "description": "MongoDB 日志库"
    },
    {
      "name": "mongodb-cluster",
      "type": "mongodb",
      "uri": "mongodb://${DB_MONGO_USER}:${DB_MONGO_PASSWORD}@mongo1.example.com:27017,mongo2.example.com:27017/mydb?replicaSet=rs0&authSource=admin",
      "database": "mydb",
      "description": "MongoDB 集群 (Replica Set, uri 优先于 host/port)"
    },
    {
      "name": "mysql-via-ssh",
      "type": "mysql",
      "host": "10.0.0.1",
      "port": 3306,
      "user": "${DB_MYSQL_USER}",
      "password": "${DB_MYSQL_PASSWORD}",
      "database": "production",
      "description": "MySQL (SSH 隧道)",
      "ssh": {
        "enabled": true,
        "host": "bastion.example.com",
        "port": 22,
        "username": "deploy",
        "privateKey": "~/.ssh/id_rsa"
      }
    },
    {
      "name": "mongodb-cluster-via-ssh",
      "type": "mongodb",
      "uri": "mongodb://${DB_MONGO_USER}:${DB_MONGO_PASSWORD}@172.16.0.1:27017,172.16.0.2:27017/mydb?replicaSet=rs0&authSource=admin",
      "database": "mydb",
      "description": "MongoDB 集群 (SSH 隧道, uri 中所有节点地址会被替换为本地隧道入口)",
      "ssh": {
        "enabled": true,
        "host": "bastion.example.com",
        "port": 22,
        "username": "deploy",
        "privateKey": "~/.ssh/id_rsa"
      }
    },
    {
      "name": "sqlite-local",
      "type": "sqlite",
      "filePath": "./data/local.db",
      "description": "SQLite 本地数据库"
    },
    {
      "name": "goldendb-demo",
      "type": "goldendb",
      "host": "localhost",
      "port": 3306,
      "user": "root",
      "password": "${DB_GOLDENDB_PASSWORD}",
      "database": "goldendb_test",
      "description": "中兴 GoldenDB"
    },
    {
      "name": "highgo-demo",
      "type": "highgo",
      "host": "localhost",
      "port": 5866,
      "user": "highgo",
      "password": "${DB_HIGHGO_PASSWORD}",
      "database": "highgo_test",
      "description": "瀚高数据库"
    },
    {
      "name": "vastbase-demo",
      "type": "vastbase",
      "host": "localhost",
      "port": 5432,
      "user": "vastbase",
      "password": "${DB_VASTBASE_PASSWORD}",
      "database": "vastbase_test",
      "description": "海量数据 Vastbase"
    }
  ],
  "settings": {
    "allowWrite": false,
    "ddlWhitelist": [],
    "logLevel": "info"
  }
}
